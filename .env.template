# -------------------------------------
# VARIABLES DE BASE DE DATOS (MariaDB)
# -------------------------------------
MOODLE_DB_TYPE=mariadb
# Debe coincidir con el nombre del servicio en docker-compose
MOODLE_DB_HOST=db
MOODLE_DB_NAME=moodle_db
MOODLE_DB_USER=moodleuser
MOODLE_DB_PASS=change_me_db_user_password
MOODLE_DB_PREFIX=mdl_
# Contraseña de administrador del motor de base de datos
MOODLE_DB_ROOT_PASS=change_me_db_root_password

# -------------------------------------
# VARIABLES DE LA APLICACIÓN (Moodle)
# -------------------------------------
MOODLE_URL=http://172.16.83.125:8080
MOODLE_DATA_DIR=/var/www/moodledata
MOODLE_REVERSE_PROXY=false

# -------------------------------------
# VARIABLES DE INSTALACIÓN INICIAL
# -------------------------------------
# Credenciales del administrador (primera instalación)
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=Admin123!
MOODLE_ADMIN_EMAIL=admin@example.com

# Configuración del sitio
MOODLE_SITE_NAME=OKIP - Plataforma Educativa
MOODLE_SITE_SHORTNAME=okip
MOODLE_LANG=es

# -------------------------------------
# VARIABLES DE SMTP (Opcional)
# -------------------------------------
# Descomenta y configura si necesitas envío de emails
# MOODLE_SMTP_HOST=smtp.gmail.com
# MOODLE_SMTP_PORT=587
# MOODLE_SMTP_USER=tu_email@gmail.com
# MOODLE_SMTP_PASS=tu_contraseña_de_aplicacion
# MOODLE_SMTP_FROM=noreply@moodle.local
# MOODLE_SMTP_SECURE=tls

# -------------------------------------
# VARIABLES DEL SISTEMA
# -------------------------------------
TZ=America/Mexico_City
