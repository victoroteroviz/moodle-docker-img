# -------------------------------------
# VARIABLES DE BASE DE DATOS (MariaDB)
# -------------------------------------
MOODLE_DB_TYPE=mysqli
# El host DEBE coincidir con el nombre del servicio en docker-compose (db)
MOODLE_DB_HOST=db
MOODLE_DB_NAME=moodle_db
MOODLE_DB_USER=moodleuser
MOODLE_DB_PASS=S3cur3P@ssw0rd!
MOODLE_DB_PREFIX=mdl_
# Contraseña de administrador exclusiva para el motor de base de datos
MOODLE_DB_ROOT_PASS=SuperS3cretR00t!

# -------------------------------------
# VARIABLES DE LA APLICACIÓN (Moodle)
# -------------------------------------
MOODLE_URL=http://localhost:8080
MOODLE_DATA_DIR=/var/www/moodledata
MOODLE_REVERSE_PROXY=false

# -------------------------------------
# VARIABLES DEL SISTEMA
# -------------------------------------
# Ajusta esto a tu zona horaria local
TZ=America/Mexico_City