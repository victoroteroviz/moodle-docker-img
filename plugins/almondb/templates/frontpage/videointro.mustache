{{!
    @template theme_almondb/frontpage/videointro

    Popup intro video shown on the front page to visitors without an active session.

    Context variables required for this template:
    * videointrourl - The video source URL (uploaded file or external link)
    * videointroposter - Optional poster image URL
    * videointroautoplay - Whether the video should autoplay
    * videointroloop - Whether the video should loop
    * videointroonce - Whether to show the video only once per browser session
}}
<div id="almondb-videointro" class="almondb-videointro-overlay" data-once="{{#videointroonce}}1{{/videointroonce}}{{^videointroonce}}0{{/videointroonce}}"
    role="dialog" aria-modal="true" aria-label="{{#str}} videointro, theme_almondb {{/str}}">
    <div class="almondb-videointro-dialog">
        <button type="button" class="almondb-videointro-close" aria-label="{{#str}} closebuttontitle, core {{/str}}">
            <i class="fa fa-times" aria-hidden="true"></i>
        </button>
        {{#videointroembed}}
            <div class="almondb-videointro-embed">
                <iframe src="{{{ videointroembedurl }}}" title="{{#str}} videointro, theme_almondb {{/str}}"
                    allow="autoplay; fullscreen; encrypted-media; picture-in-picture" allowfullscreen></iframe>
            </div>
        {{/videointroembed}}
        {{^videointroembed}}
            <video class="almondb-videointro-video" muted playsinline controls preload="auto"
                {{#videointroautoplay}}autoplay{{/videointroautoplay}}
                {{#videointroloop}}loop{{/videointroloop}}
                {{#videointroposter}}poster="{{{ videointroposter }}}"{{/videointroposter}}>
                <source src="{{{ videointrourl }}}"{{#videointromime}} type="{{ videointromime }}"{{/videointromime}}>
            </video>
        {{/videointroembed}}
    </div>
</div>
{{#js}}
(function() {
    var overlay = document.getElementById('almondb-videointro');
    if (!overlay) {
        return;
    }
    var once = overlay.getAttribute('data-once') === '1';
    var storekey = 'almondb_videointro_seen';
    // Respect the "once per session" option.
    if (once && window.sessionStorage && sessionStorage.getItem(storekey)) {
        overlay.parentNode.removeChild(overlay);
        return;
    }
    var video = overlay.querySelector('.almondb-videointro-video');
    var closed = false;
    function closeIntro() {
        if (closed) {
            return;
        }
        closed = true;
        overlay.classList.add('almondb-videointro-hidden');
        if (video) {
            try {
                video.pause();
            } catch (e) {
                // Ignore.
            }
        }
        document.body.classList.remove('almondb-videointro-open');
        if (once && window.sessionStorage) {
            sessionStorage.setItem(storekey, '1');
        }
        window.setTimeout(function() {
            if (overlay && overlay.parentNode) {
                overlay.parentNode.removeChild(overlay);
            }
        }, 400);
    }
    overlay.querySelector('.almondb-videointro-close').addEventListener('click', closeIntro);
    overlay.addEventListener('click', function(e) {
        if (e.target === overlay) {
            closeIntro();
        }
    });
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' || e.keyCode === 27) {
            closeIntro();
        }
    });
    document.body.classList.add('almondb-videointro-open');
    if (video) {
        var playpromise = video.play();
        if (playpromise && playpromise.catch) {
            playpromise.catch(function() {
                // Autoplay was blocked; the user can still use the controls.
            });
        }
        video.addEventListener('ended', function() {
            if (!video.loop) {
                closeIntro();
            }
        });
    }
})();
{{/js}}
