{{!
    @template core/user_action_menu_submenu_items

    Template for the submenus in the user action menu (overridden by theme_almondb to
    show a flag on the left of each language option, matching the landing page menu).

    Context variables required for this template:
    * items - The submenu items
      * link - If a link is provided render it.
        * title - The title added to the link.
        * text - The text to be shown for the link.
        * url - The href for the link.
        * isactive - (Optional) Whether the item is currently active (has been selected).
        * flagurl - (Optional) The flag image URL for a language item (added by theme_almondb).

    Example context (json):
    {
        "items": {
            "link": {
                "title": "Submenu item 1",
                "text": "Submenu item 1",
                "url": "https://example.com/",
                "isactive": 0
            }
        }
    }
}}
{{#items}}
    {{#link}}
        {{! Language items reuse the exact markup of the landing page menu so the flag
            and text align the same way. Bootstrap's ps-5 is "padding-left: 2rem
            !important", which would beat any flag-aligned padding, so it is dropped
            here and kept only for non-language submenu items. }}
        {{#flagurl}}
            <a href="{{{url}}}" class="dropdown-item langmenu-item d-flex align-items-center" role="menuitem" tabindex="-1" {{#isactive}}aria-current="true"{{/isactive}}
                    {{#attributes}}{{key}}="{{value}}" {{/attributes}}>
                <img class="langflag me-2" src="{{flagurl}}" alt="" aria-hidden="true">
                <span class="langmenu-text">{{text}}</span>
            </a>
        {{/flagurl}}
        {{^flagurl}}
            <a href="{{{url}}}" class="dropdown-item ps-5" role="menuitem" tabindex="-1" {{#isactive}}aria-current="true"{{/isactive}}
                    {{#attributes}}{{key}}="{{value}}" {{/attributes}}>
                {{text}}
            </a>
        {{/flagurl}}
    {{/link}}
{{/items}}
